<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Thème principal -->
    <style name="Theme.LudoMasterPro" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="android:windowBackground">@color/bg_dark</item>

        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>

        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/accent</item>

    </style>

    <!-- Thème Splash Screen -->
    <style name="Theme.LudoMasterPro.Splash" parent="Theme.LudoMasterPro">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

</resources>
